# Auth0 Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Required: Auth0 Client ID (from Auth0 dashboard > Applications > Settings)
clientId=YOUR_CLIENT_ID_HERE

# Required: Auth0 Domain (from Auth0 dashboard > Applications > Settings)
# Format: xxxx.us.auth0.com or xxxx.xx.auth0.com
domain=YOUR_DOMAIN_HERE

# Optional: Custom Audience
# If not provided, defaults to https://{domain}/api/v2/
# Example: "zefr-brand-capture" or "https://api.your-company.com"
# audience=zefr-brand-capture

# Optional: Custom Scope
# Space-separated list of scopes to request
# If not provided, auth0-spa-js will use default scopes
# Example: "openid profile email zefr-bsx" or "openid profile email read:reports write:reports"
# scope=openid profile email zefr-bsx

# Optional: Prompt Parameter
# Controls authentication prompt behavior
# Common values: "login", "consent", "none"
# If not provided, Auth0 will use default behavior
# prompt=login
